# Rust
/target

# clean-room mounts — never committed (NOT mounted in M0; see CLAUDE.md)
references/

# TS
node_modules/
dist/
*.tsbuildinfo

# wasm-bindgen build outputs (regenerated by scripts/build-wasm.sh;
