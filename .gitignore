# .gitkeep + SOURCE.md keep the directory + the attribution record.
vendor/duckdb-wasm/*.wasm
vendor/duckdb-wasm/*.js
vendor/duckdb-wasm/*.mjs
vendor/duckdb-wasm/*.worker.js
vendor/duckdb-wasm/dist/

# oracle venv (native-DuckDB differential harness, if ever local)
